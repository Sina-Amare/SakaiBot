# ============================================================================
# SAKAIBOT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# Documentation: https://github.com/Sina-Amare/SakaiBot#configuration
# ============================================================================

# ============================================================================
# TELEGRAM API CONFIGURATION (Required)
# ============================================================================
# Get these from https://my.telegram.org -> API Development Tools
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_PHONE_NUMBER=+1234567890
TELEGRAM_SESSION_NAME=sakaibot_session

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================
# Primary provider: "openrouter" or "gemini"
LLM_PROVIDER=gemini
# Fallback provider: "openrouter", "gemini", or "none"
# Default behavior if unset: Gemini primary falls back to OpenRouter;
# OpenRouter primary has no fallback.
LLM_FALLBACK_PROVIDER=openrouter

# ----------------------------------------------------------------------------
# OpenRouter Configuration (Required - automatic fallback for all AI commands)
# ----------------------------------------------------------------------------
# OpenRouter is used for:
#   1. Image prompt enhancement
#   2. Automatic fallback for EVERY AI command (/prompt, /translate,
#      /analyze, /tellme, STT summary) whenever the primary provider
#      (Gemini) fails - keys exhausted, quota, or 403 / network geo-block.
# Get API keys from: https://openrouter.ai/
#
# Free (":free") models are rate-limited per key - add multiple keys so the
# bot can rotate between them.
OPENROUTER_API_KEY_1=sk-or-v1-your-openrouter-key-here
# OPENROUTER_API_KEY_2=sk-or-v1-optional-second-key
# OPENROUTER_API_KEY_3=sk-or-v1-optional-third-key
# OPENROUTER_API_KEY_4=sk-or-v1-optional-fourth-key

# Fallback model (both task tiers). Any OpenRouter model ID works; ":free"
# variants cost nothing but are slower and rate-limited.
OPENROUTER_MODEL_PRO=deepseek/deepseek-v4-flash:free
OPENROUTER_MODEL_FLASH=deepseek/deepseek-v4-flash:free
# Legacy/default model for unknown task types
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# Optional per-command overrides. Leave blank/commented to use PRO/FLASH tiers.
# OPENROUTER_MODEL_PROMPT=deepseek/deepseek-v4-flash:free
# OPENROUTER_MODEL_ANALYZE=deepseek/deepseek-v4-flash:free
# OPENROUTER_MODEL_TELLME=deepseek/deepseek-v4-flash:free
# OPENROUTER_MODEL_TRANSLATE=deepseek/deepseek-v4-flash:free
# OPENROUTER_MODEL_PROMPT_ENHANCER=deepseek/deepseek-v4-flash:free
# OPENROUTER_MODEL_VOICE_SUMMARY=deepseek/deepseek-v4-flash:free

# ----------------------------------------------------------------------------
# Google Gemini Configuration (Primary Provider with Auto-Rotation)
# ----------------------------------------------------------------------------
# Get API keys from: https://aistudio.google.com/apikey
# Multiple API keys enable auto-rotation when hitting rate limits
GEMINI_API_KEY_1=your_gemini_api_key_here
# GEMINI_API_KEY_2=optional_second_key
# GEMINI_API_KEY_3=optional_third_key
# GEMINI_API_KEY_4=optional_fourth_key

# Separate key for TTS (optional, uses main key if not set)
# GEMINI_API_KEY_TTS=optional_dedicated_tts_key

# Task-specific models
GEMINI_MODEL_PRO=gemini-2.5-flash
GEMINI_MODEL_FLASH=gemini-3.1-flash-lite
# Legacy/default model for unknown task types
GEMINI_MODEL=gemini-3.1-flash-lite
# Used when the Pro tier hits quota
GEMINI_MODEL_PRO_FALLBACK=gemini-3.1-flash-lite

# Optional per-command overrides. Leave blank/commented to use PRO/FLASH tiers.
GEMINI_MODEL_PROMPT=gemini-2.5-flash
GEMINI_MODEL_ANALYZE=gemini-2.5-flash
GEMINI_MODEL_TELLME=gemini-2.5-flash
GEMINI_MODEL_TRANSLATE=gemini-3.1-flash-lite
GEMINI_MODEL_PROMPT_ENHANCER=gemini-3.1-flash-lite
GEMINI_MODEL_VOICE_SUMMARY=gemini-3.1-flash-lite

# Text-to-speech
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Orus

# Speech-to-text summary (STT transcription itself uses Google Web Speech API)
STT_AI_SUMMARY_ENABLED=false
GEMINI_SUMMARY_MODEL=gemini-3.1-flash-lite

# ============================================================================
# IMAGE GENERATION - CLOUDFLARE WORKERS (Optional)
# ============================================================================
# Image generation requires Cloudflare Workers.

# Flux Worker (Fast generation, no auth required)
# Public community worker (may have rate limits):
FLUX_WORKER_URL=https://image-smoke-ad69.fa-ra9931143.workers.dev

# SDXL Worker (High Quality, requires your own worker)
# You must deploy your own SDXL worker
# SDXL_WORKER_URL=https://your-sdxl-worker.workers.dev
# SDXL_API_KEY=your_sdxl_bearer_token

# ============================================================================
# USERBOT CONFIGURATION
# ============================================================================
USERBOT_MAX_ANALYZE_MESSAGES=10000

# ============================================================================
# PATHS
# ============================================================================
# FFmpeg is required for audio processing (TTS/STT)
# Download from: https://ffmpeg.org/download.html

# Windows example:
# PATHS_FFMPEG_EXECUTABLE=C:\ffmpeg\bin\ffmpeg.exe

# Linux/macOS example:
# PATHS_FFMPEG_EXECUTABLE=/usr/bin/ffmpeg

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
DEBUG=false
